# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Optional: Only needed if you want to sync users via webhooks
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# MongoDB Database
# Get this from https://cloud.mongodb.com
MONGODB_URI=your_mongodb_connection_string

# Example:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/attendai?retryWrites=true&w=majority
# CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
